<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.obsidian.digest.sync</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/path/to/obsidian-digest-sync.sh</string>
    </array>

    <key>WatchPaths</key>
    <array>
        <string>/path/to/nursing-literature-digests</string>
        <string>/path/to/psychiatry-medicine-digests</string>
        <string>/path/to/ki-pflege-digests</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/path/to/obsidian-digest-sync.out.log</string>
    <key>StandardErrorPath</key>
    <string>/path/to/obsidian-digest-sync.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>HOME</key>
        <string>/path/to/home</string>
    </dict>
</dict>
</plist>
